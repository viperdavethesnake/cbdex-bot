# Base RPC — Alchemy (free tier sufficient for 90-day gas pull)
# Get your key at: https://www.alchemy.com/
BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY_HERE

# The Graph — required for Truth Path queries (Aerodrome subgraph)
# Get your key at: https://thegraph.com/studio/ → API Keys → Create API Key
# Key is a 32+ character hex string
THEGRAPH_API_KEY=YOUR_THEGRAPH_API_KEY_HERE

# GeckoTerminal — no API key required (Fast Path OHLCV)
