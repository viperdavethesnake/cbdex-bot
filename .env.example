# Base Mainnet RPC — Alchemy (free tier sufficient)
# Get your key at: https://www.alchemy.com/ → Create App → Base Mainnet
BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY_HERE

# Base Sepolia RPC — required for paper trading (testnet)
# Get your key at: https://www.alchemy.com/ → Create App → Base Sepolia
BASE_SEPOLIA_RPC_URL=https://base-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY_HERE

# The Graph — required for WETH/USDC Truth Path queries (Aerodrome CL subgraph)
# Get your key at: https://thegraph.com/studio/ → API Keys → Create API Key
THEGRAPH_API_KEY=YOUR_THEGRAPH_API_KEY_HERE

# Hot wallet private key — TESTNET ONLY for paper trading
# Generate a fresh wallet: python3 -c "from eth_account import Account; a = Account.create(); print(a.key.hex(), a.address)"
# Fund with Sepolia ETH from: https://www.alchemy.com/faucets/base-sepolia
# NEVER use a wallet that holds real funds
# NEVER commit a real private key
HOT_WALLET_PRIVATE_KEY=YOUR_TESTNET_ONLY_PRIVATE_KEY_HERE

# Aerodrome Router on Base Sepolia (verify before use)
# Check: https://sepolia.basescan.org for current Aerodrome Sepolia deployment
SEPOLIA_ROUTER_ADDRESS=YOUR_SEPOLIA_ROUTER_ADDRESS_HERE

# GeckoTerminal — no API key required (Fast Path OHLCV)
